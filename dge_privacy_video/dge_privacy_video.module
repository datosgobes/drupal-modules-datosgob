use Drupal\Core\Render\Markup;
use Drupal\Core\Security\TrustedCallbackInterface;
use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_page_attachments().
 */
function dge_privacy_video_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'dge_privacy_video/video_consent_oembed';

  $attachments['#attached']['drupalSettings']['dge_privacy_video'] = [
    'aria_label' => t('Vídeo bloqueado por preferencias de cookies'),
    'message' => t('Para ver este vídeo, acepta la categoría <strong>Vídeos</strong>.'),
    'button_text' => t('Configurar cookies'),
  ];
}


/**
 * Implements hook_preprocess_media_oembed_iframe().
 * 
 * This hook handles videos added through the Media Library.
*/
function dge_privacy_video_preprocess_media_oembed_iframe(array &$variables) {
  if (empty($variables['media'])) {
    return;
  }
  $iframe_html = (string) $variables['media'];
  $modified_html = $iframe_html;

  if (strpos($iframe_html, 'youtube.com/embed') !== false) {
    $modified_html = str_replace('youtube.com/embed', 'youtube-nocookie.com/embed', $modified_html);
  }

  if (strpos($iframe_html, 'player.vimeo.com/video') !== false) {
    if (strpos($iframe_html, 'dnt=1') === false) {
      $pattern = '/(<iframe[^>]+src="[^"]+)/i';
      $separator = strpos($iframe_html, '?') !== false ? '&' : '?';
      $replacement = '$1' . $separator . 'dnt=1';
      $modified_html = preg_replace($pattern, $replacement, $modified_html);
    }
  }

  $variables['media'] = Markup::create($modified_html);
}



/**
 * Implements hook_entity_view_alter().
 * 
 * Attaches a #post_render callback to the text field to handle raw iframes.
 */
function dge_privacy_video_entity_view_alter(array &$build, EntityInterface $entity, $display) {
  $text_field_types = ['text', 'text_long', 'text_with_summary'];

  foreach ($build as $field_name => &$field_build) {
    
    if (!is_array($field_build)) {
      continue;
    }

    if (isset($field_build['#theme']) && $field_build['#theme'] === 'field') {
      $field_definition = $entity->getFieldDefinition($field_name);
      if ($field_definition) {
        if (in_array($field_definition->getType(), $text_field_types)) {
          $field_build['#post_render'][] = [DgePrivacyVideoRawIframeProcessor::class, 'processFieldOutput'];
        }
      }
    }
  }
}

/**
 * Defines a trusted callback for modifying raw iframes in rendered field output.
 */
class DgePrivacyVideoRawIframeProcessor implements TrustedCallbackInterface {
  /**
   * {@inheritdoc}
   */
  public static function trustedCallbacks() {
    return ['processFieldOutput'];
  }

  /**
   * #post_render callback to find and modify raw YouTube/Vimeo iframes.
   */
  public static function processFieldOutput($content, array $element) {
    // This pattern finds all iframes in the content.
    $pattern = '/<iframe(.*?)>/i';

    $new_content = preg_replace_callback($pattern, function ($matches) {
      $iframe_attributes = $matches[1];
      $full_iframe_tag = '<iframe ' . $iframe_attributes . '></iframe>';

      if (strpos($iframe_attributes, 'media-oembed-content') !== false) {
        return $full_iframe_tag;
      }
      
      if (preg_match('/src=(["\'])(.*?)\1/i', $iframe_attributes, $src_matches)) {
        $original_src = $src_matches[2];
        $modified_src = $original_src;
        $was_modified = false;

        if (strpos($original_src, 'youtube.com/embed') !== false) {
          $modified_src = str_replace('youtube.com/embed', 'youtube-nocookie.com/embed', $original_src);
          $was_modified = true;
        }
        elseif (strpos($original_src, 'vimeo.com/video') !== false) {
          if (strpos($original_src, 'dnt=1') === false) {
            $separator = strpos($original_src, '?') !== false ? '&' : '?';
            $modified_src .= $separator . 'dnt=1';
          }
          $was_modified = true;
        }

        if ($was_modified) {
          $new_attributes = str_replace('src="', 'data-src="', $iframe_attributes);
          $new_attributes = str_replace($original_src, $modified_src, $new_attributes);
          if (strpos($new_attributes, 'class="') !== false) {
            $new_attributes = str_replace('class="', 'class="dge-privacy-video-processed ', $new_attributes);
          }
          else {
            $new_attributes = 'class="dge-privacy-video-processed" ' . $new_attributes;
          }
          return '<iframe ' . $new_attributes . '></iframe>';
        }
      }

      return $full_iframe_tag;
    }, $content);

    return $new_content;
  }
}